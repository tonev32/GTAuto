@{
    ViewData["Title"] = "За нас";
}

<style>
    .about-section {
        padding: 60px 0;
    }

    .about-img {
        width: 100%;
        border-radius: 15px;
        margin-bottom: 20px;
    }

    .section-box {
        margin-bottom: 40px;
    }
</style>

<div class="container about-section">

    <!-- СОБСТВЕНИК -->
    <div class="row section-box align-items-center">
        <div class="col-md-4">
            <img src="/images/Owner.jpg" class="about-img">
        </div>
        <div class="col-md-8">
            <h2>Собственик</h2>
            <p>
                Казвам се Хабиб и съм собственик на GTAuto.
                Занимавам се с автомобили от години и лично подбирам всяка кола.
            </p>
            <p>
                Работя сам и държа на коректността – няма посредници и излишни разходи.
            </p>
        </div>
    </div>

    <!-- ИСТОРИЯ -->
    <div class="section-box">
        <h2>История на GTAuto</h2>
        <p>
            GTAuto започна като малък бизнес с цел да предлага качествени автомобили
            на реални цени. С времето се разви благодарение на доволни клиенти и
            коректно отношение.
        </p>
    </div>

    <!-- ЛОКАЦИЯ -->
    <div class="section-box">
        <h2>Къде да ни намерите</h2>
        <p>
            Автокъщата се намира в София.
            От южна страна на Американския колеж.
        </p>
    </div>

    <!-- СНИМКА НА АВТОКЪЩАТА -->
    <div class="section-box">
        <h2>Автокъщата</h2>
        <img src="/images/house.jpg" class="about-img">
    </div>

</div>