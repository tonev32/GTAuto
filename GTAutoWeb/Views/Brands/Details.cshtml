@model GTAuto.Data.Models.Brand

<h1>Brand Details</h1>

<hr/>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>
</dl>

<h4>Models</h4>

<ul>
    @foreach (var item in Model.Models)
    {
        <li>@item.Name</li>
    }
</ul>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back</a>